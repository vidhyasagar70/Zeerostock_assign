          },
          "response": []
        }
      ]
    },
    {
      "name": "Suppliers",
      "item": [
        {
          "name": "POST Create Supplier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Supplier id is present\", function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property(\"id\");",
                  "  pm.collectionVariables.set(\"supplierId\", body.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Prime Warehouse Supplies\",\n  \"city\": \"Dallas\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/supplier",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "supplier"
              ]
            },
            "description": "Create a supplier"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "POST Create Inventory",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplier_id\": \"{{supplierId}}\",\n  \"product_name\": \"Heavy Duty Cart\",\n  \"category\": \"Logistics\",\n  \"quantity\": 12,\n  \"price\": 249.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "inventory"
              ]
            },
            "description": "Create inventory for an existing supplier. Run supplier create first to auto-fill supplierId."
          },
          "response": []
        },
        {
          "name": "GET Inventory",
          "request": {
            "method": "GET",
